{% extends "main.j2" %}
{% block content %}
<h1>Game Genres</h1>

{% if request.args.get('error') == 'genre_in_use' %}
<p style="color:red;">Cannot delete genre: referenced by board games.</p>
{% endif %}

<form method="POST" action="/add_genre">
    <input type="text" name="genre" required>
    <button type="submit">Add</button>
</form>

<table border="1">
<tr><th>ID</th><th>Genre</th><th>Delete</th></tr>
{% for g in genres %}
<tr>
<td>{{ g.gameGenreID }}</td>
<td>{{ g.genre }}</td>
<td>
<form method="POST" action="/delete_genre">
<input type="hidden" name="gameGenreID" value="{{ g.gameGenreID }}">
<button>Delete</button>
</form>
</td>
</tr>
{% endfor %}
</table>
{% endblock %}
