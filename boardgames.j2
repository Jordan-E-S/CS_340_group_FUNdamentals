{% extends "main.j2" %}
{% block content %}
<h1>Board Games</h1>

<form method="POST" action="/add_boardgame">
Title: <input name="title" required>
Publisher: <input name="publisher" required>
Min: <input type="number" name="minPlayers" required>
Max: <input type="number" name="maxPlayers" required>
Complexity: <input type="number" name="complexity" required>

<select name="gameGenreID">
{% for g in genres %}
<option value="{{ g.gameGenreID }}">{{ g.genre }}</option>
{% endfor %}
</select>

<button>Add</button>
</form>

<table border="1">
<tr>
<th>ID</th><th>Title</th><th>Publisher</th>
<th>Min</th><th>Max</th><th>Complexity</th><th>Genre</th>
</tr>
{% for bg in boardgames %}
<tr>
<td>{{ bg.boardGameID }}</td>
<td>{{ bg.title }}</td>
<td>{{ bg.publisher }}</td>
<td>{{ bg.minPlayers }}</td>
<td>{{ bg.maxPlayers }}</td>
<td>{{ bg.complexity }}</td>
<td>{{ bg.genre }}</td>
</tr>
{% endfor %}
</table>
{% endblock %}
