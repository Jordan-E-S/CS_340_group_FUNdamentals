{% extends "main.j2" %}
{% block content %}
<h1>Patrons</h1>

{% if request.args.get('error') == 'patron_has_checkouts' %}
<p style="color:red;">Cannot delete patron with active checkouts.</p>
{% endif %}

<form method="POST" action="/add_patron">
First: <input name="firstName" required>
Last: <input name="lastName" required>
Email: <input name="email" required>
Phone: <input name="phoneNumber">
<button>Add</button>
</form>

<table border="1">
<tr><th>ID</th><th>Name</th><th>Email</th><th>Delete</th></tr>
{% for p in patrons %}
<tr>
<td>{{ p.patronID }}</td>
<td>{{ p.firstName }} {{ p.lastName }}</td>
<td>{{ p.email }}</td>
<td>
<form method="POST" action="/delete_patron">
<input type="hidden" name="patronID" value="{{ p.patronID }}">
<button>Delete</button>
</form>
</td>
</tr>
{% endfor %}
</table>
{% endblock %}
