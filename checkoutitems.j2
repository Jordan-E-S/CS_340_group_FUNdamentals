{% extends "main.j2" %}
{% block content %}
<h1>Checkout Items</h1>

<form method="POST" action="/add_checkoutitem">
<select name="checkoutID">
{% for c in checkouts %}
<option value="{{ c.checkoutID }}">
{{ c.checkoutID }} - {{ c.patronName }}
</option>
{% endfor %}
</select>

<select name="boardGameID">
{% for g in boardgames %}
<option value="{{ g.boardGameID }}">{{ g.title }}</option>
{% endfor %}
</select>

<button>Add</button>
</form>

<table border="1">
<tr><th>ID</th><th>Checkout</th><th>Game</th><th>Delete</th></tr>
{% for ci in checkoutitems %}
<tr>
<td>{{ ci.checkoutItemID }}</td>
<td>{{ ci.checkoutID }}</td>
<td>{{ ci.title }}</td>
<td>
<form method="POST" action="/delete_checkoutitem">
<input type="hidden" name="checkoutItemID" value="{{ ci.checkoutItemID }}">
<button>Delete</button>
</form>
</td>
</tr>
{% endfor %}
</table>
{% endblock %}
